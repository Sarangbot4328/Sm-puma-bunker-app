{
  "name": "sm-puma-bunker-calculator-android",
  "version": "0.1.0",
  "description": "Offline Android port of the SM PUMA bunker sounding calculator.",
  "author": "Yoon Hyung Guk",
  "private": true,
  "scripts": {
    "serve": "node serve.js",
    "cap:add:android": "npx cap add android",
